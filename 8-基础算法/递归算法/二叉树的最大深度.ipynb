   "source": [
    "class Solution:\n",
    "    def maxDepth(self, root: Optional[TreeNode]) -> int:\n",
    "        if not root:\n",
    "            return 0\n",
    "        \n",
    "        maxLeft = self.maxDepth(root.left)\n",
    "        maxRight = self.maxDepth(root.right)\n",
    "\n",
    "        return 1 + max(maxLeft + maxRight)"
   ]
  }
