   "source": [
    "class Solution:\n",
    "    def fib(self, n: int) -> int:\n",
    "        if n == 0:\n",
    "            return 0\n",
    "        if n == 1:\n",
    "            return 1\n",
    "        if n >= 2:\n",
    "            return self.fib(n - 1) + self.fib(n - 2)"
   ]
  }
