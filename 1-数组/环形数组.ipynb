   "source": [
    "使用取余的方法得到环形数组"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "1678a2e4",
   "metadata": {},
   "outputs": [],
   "source": [
    "arr = [1,2,3,4,5]\n",
    "n = len(arr)\n",
    "index = 0\n",
    "while True:\n",
    "    # 在环形数组中转圈\n",
    "    print(arr[index % n])\n",
    "    index += 1"
   ]
  }
 ],
